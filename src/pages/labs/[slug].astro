---
import { preferredLocaleFromAcceptLanguage } from '../../lib/i18n';

const preferredLocale = preferredLocaleFromAcceptLanguage(Astro.request.headers.get('accept-language'));
const slug = Astro.params.slug;

if (!slug) {
  return Astro.redirect(new URL(`/${preferredLocale}/labs`, Astro.url).toString(), 302);
}

return Astro.redirect(new URL(`/${preferredLocale}/labs/${slug}`, Astro.url).toString(), 302);
---
